// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MEMBER
  SHOP
}

enum GroupMemberRole {
  ADMIN
  MEMBER
}

enum BucketCategory {
  FOOD
  MEDICINE
  TOILETRIES
  ELECTRICITY
  BABY_PRODUCTS
}

enum RotationStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum CreditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GrantCycleStatus {
  ACTIVE
  COMPLETED
}

enum RepaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum StoreCreditType {
  CREDIT
  DEBIT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(MEMBER)
  name         String
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  shop               Shop?
  customerProfile    CustomerProfile?
  groupMemberships   GroupMember[]
  creditRequests     CreditRequest[]   @relation("CreditRequestRequester")
  approvedRequests   CreditRequest[]   @relation("CreditRequestApprover")
  rotationCycles     RotationCycle[]
  grantCycles        GrantCycle[]
  repaymentSchedules RepaymentSchedule[]
  storeCredit        StoreCredit?
  storeCreditHistory StoreCreditHistory[]
  notifications      Notification[]

  @@map("users")
}

model Area {
  id          String  @id @default(cuid())
  name        String
  province    String
  coordinates String? // JSON string for map coordinates
  createdAt   DateTime @default(now())

  // Relations
  shops            Shop[]
  customerProfiles CustomerProfile[]
  groups           Group[]

  @@map("areas")
}

model Shop {
  id       String  @id @default(cuid())
  name     String
  userId   String  @unique
  areaId   String
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  area Area @relation(fields: [areaId], references: [id])

  @@map("shops")
}

model CustomerProfile {
  id                 String  @id @default(cuid())
  userId             String  @unique
  sassaId            String  @unique
  areaId             String
  creditScore        Int     @default(50) // 0-100
  monthlyGrantAmount Decimal @default(350.00)
  isActive           Boolean @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  area Area @relation(fields: [areaId], references: [id])

  @@map("customer_profiles")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  areaId      String
  maxMembers  Int      @default(10)
  rotationDay Int      @default(1) // Day of month for rotation
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  area           Area            @relation(fields: [areaId], references: [id])
  members        GroupMember[]
  wallet         GroupWallet?
  rotationCycles RotationCycle[]
  creditRequests CreditRequest[]

  @@map("groups")
}

model GroupMember {
  id       String          @id @default(cuid())
  groupId  String
  userId   String
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupWallet {
  id       String  @id @default(cuid())
  groupId  String  @unique
  balance  Decimal @default(0)
  currency String  @default("ZAR")

  // Relations
  group   Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  buckets GroupBucket[]

  @@map("group_wallets")
}

model GroupBucket {
  id              String         @id @default(cuid())
  walletId        String
  category        BucketCategory
  allocatedAmount Decimal        @default(0)
  spentAmount     Decimal        @default(0)

  // Relations
  wallet GroupWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, category])
  @@map("group_buckets")
}

model RotationCycle {
  id              String         @id @default(cuid())
  groupId         String
  month           Int
  year            Int
  recipientUserId String
  amount          Decimal       
  status          RotationStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  recipient User  @relation(fields: [recipientUserId], references: [id])

  @@map("rotation_cycles")
}

model CreditRequest {
  id          String              @id @default(cuid())
  requesterId String
  groupId     String
  amount      Decimal            
  reason      String
  status      CreditRequestStatus @default(PENDING)
  approvedBy  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relations
  requester User   @relation("CreditRequestRequester", fields: [requesterId], references: [id])
  group     Group  @relation(fields: [groupId], references: [id])
  approver  User?  @relation("CreditRequestApprover", fields: [approvedBy], references: [id])

  @@map("credit_requests")
}

model GrantCycle {
  id          String           @id @default(cuid())
  userId      String
  month       Int
  year        Int
  grantAmount Decimal         
  spentAmount Decimal          @default(0)
  repaidAmount Decimal         @default(0)
  status      GrantCycleStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("grant_cycles")
}

model RepaymentSchedule {
  id      String          @id @default(cuid())
  userId  String
  amount  Decimal        
  dueDate DateTime
  paidAt  DateTime?
  status  RepaymentStatus @default(PENDING)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("repayment_schedules")
}

model StoreCredit {
  id       String  @id @default(cuid())
  userId   String  @unique
  balance  Decimal @default(0)
  currency String  @default("ZAR")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("store_credits")
}

model StoreCreditHistory {
  id          String          @id @default(cuid())
  userId      String
  amount      Decimal
  type        StoreCreditType
  description String
  createdAt   DateTime        @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("store_credit_history")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // CREDIT_APPROVED | CREDIT_REJECTED | GENERAL
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
