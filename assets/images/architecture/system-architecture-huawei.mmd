flowchart TB
  %% e-Khadi architecture: current app shape + Huawei target runtime

  subgraph ClientLayer[Client Layer]
    USERS["Users\nMember / Shop / Admin"]
    BROWSER["Web Browser / Mobile Browser"]
    USERS --> BROWSER
  end

  subgraph FrontendLayer[Presentation Layer]
    NEXT["Next.js 14 App (App Router)\nRole-based dashboards + Auth UI"]
    EDGE["Edge Middleware\nRoute protection + role checks"]
    NEXT --> EDGE
  end

  subgraph ApiLayer[API Layer]
    API["Next.js API Routes\nDomain APIs (credit, groups, repayments)"]
    APIG["Huawei API Gateway (APIG)\nRate limiting + secure ingress"]
    NEXT --> API
    API --> APIG
  end

  subgraph ServiceLayer[Business Service Layer - Huawei]
    FG["FunctionGraph\nScoring, approval, repayment logic"]
    APIG --> FG
  end

  subgraph DataLayer[Data and Integration Layer]
    RDS["RDS for PostgreSQL\nCore transactional data"]
    OBS["Object Storage Service (OBS)\nDocuments, exports, media"]
    SMN["Simple Message Notification (SMN)\nApprovals, reminders, alerts"]
    FG --> RDS
    FG --> OBS
    FG --> SMN
  end

  subgraph SecurityNetwork[Security and Network]
    IAM["IAM\nIdentity and access control"]
    VPC["VPC + Security Groups\nPrivate network boundaries"]
  end

  IAM -. Policy Enforcement .-> APIG
  IAM -. Policy Enforcement .-> FG
  IAM -. Policy Enforcement .-> RDS
  IAM -. Policy Enforcement .-> OBS
  VPC -. Network Isolation .-> APIG
  VPC -. Network Isolation .-> FG
  VPC -. Network Isolation .-> RDS

  subgraph DeliveryOps[Delivery and Infrastructure]
    DEV["Developer Team"]
    GH["GitHub Repository"]
    GHA["GitHub Actions CI/CD"]
    TF["Terraform IaC"]
    OBSSTATE["OBS Bucket\nTerraform state"]
    LOCK["State Locking\n(lock table)"]

    DEV --> GH --> GHA --> TF
    TF --> OBSSTATE
    TF --> LOCK
    TF --> APIG
    TF --> FG
    TF --> RDS
    TF --> OBS
    TF --> SMN
    TF --> IAM
    TF --> VPC
  end

  BROWSER --> NEXT

  classDef user fill:#334155,stroke:#0f172a,color:#ffffff,stroke-width:1px;
  classDef frontend fill:#0f766e,stroke:#115e59,color:#ffffff,stroke-width:1px;
  classDef api fill:#2563eb,stroke:#1e40af,color:#ffffff,stroke-width:1px;
  classDef service fill:#b45309,stroke:#7c2d12,color:#ffffff,stroke-width:1px;
  classDef data fill:#1d4ed8,stroke:#1e3a8a,color:#ffffff,stroke-width:1px;
  classDef security fill:#047857,stroke:#065f46,color:#ffffff,stroke-width:1px;
  classDef delivery fill:#6d28d9,stroke:#4c1d95,color:#ffffff,stroke-width:1px;

  class USERS,BROWSER user;
  class NEXT,EDGE frontend;
  class API,APIG api;
  class FG service;
  class RDS,OBS,SMN data;
  class IAM,VPC security;
  class DEV,GH,GHA,TF,OBSSTATE,LOCK delivery;
