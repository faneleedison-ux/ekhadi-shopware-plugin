{
  "name": "ekhadi-remotion",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render ArchDiagram out/architecture.mp4 --codec=h264",
    "render:gif": "remotion render ArchDiagram out/architecture.gif --codec=gif",
    "render:webm": "remotion render ArchDiagram out/architecture.webm --codec=vp8",
    "stills": "bash scripts/export-stills.sh",
    "pptx": "node scripts/generate-pptx.js"
  },
  "dependencies": {
    "@remotion/cli": "4.0.290",
    "pptxgenjs": "^4.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.290"
  },
  "devDependencies": {
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "typescript": "5.5.4"
  }
}
